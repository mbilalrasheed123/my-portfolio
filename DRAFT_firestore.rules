rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ---------------------------------------------------------
    // 1. GLOBAL HELPERS
    // ---------------------------------------------------------
    function isSignedIn() { return request.auth != null; }
    function isAdmin() { 
      return isSignedIn() && 
             request.auth.token.email == "muhammadbilalrasheed78@gmail.com" &&
             request.auth.token.email_verified == true;
    }
    function isOwner(userId) { return isSignedIn() && request.auth.uid == userId; }
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }

    // ---------------------------------------------------------
    // 2. SAFETY NET
    // ---------------------------------------------------------
    match /{document=**} {
      allow read, write: if false;
    }

    // ---------------------------------------------------------
    // 3. COLLECTIONS
    // ---------------------------------------------------------

    // Public Collections (Read-Only for public, Write for Admin)
    match /projects/{projectId} {
      allow read: if true;
      allow write: if isAdmin();
    }
    
    match /certificates/{certId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /settings/{settingId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // User Profiles
    match /users/{userId} {
      allow read: if isSignedIn() && (isOwner(userId) || isAdmin());
      allow create: if isSignedIn() && isOwner(userId) &&
        incoming().keys().hasAll(['uid', 'email']) &&
        incoming().uid == request.auth.uid;
      allow update: if isSignedIn() && (isOwner(userId) || isAdmin()) &&
        incoming().uid == existing().uid; // UID is immutable
    }

    // Contact Messages (Queries)
    match /contactMessages/{messageId} {
      // Allow creation by anyone (signed in or anonymous)
      // If user is signed in, we link their UID
      allow create: if 
        incoming().keys().hasAll(['userName', 'userEmail', 'message', 'subject', 'status']) &&
        incoming().userName is string && incoming().userName.size() <= 100 &&
        incoming().userEmail is string && incoming().userEmail.size() <= 100 &&
        incoming().message is string && incoming().message.size() <= 5000 &&
        incoming().status == 'pending' &&
        (incoming().userUid == null || incoming().userUid == request.auth.uid);

      // List queries: Users can see their own messages, Admin sees all
      allow list: if isAdmin() || (isSignedIn() && resource.data.userUid == request.auth.uid);
      
      // Get single message
      allow get: if isAdmin() || (isSignedIn() && resource.data.userUid == request.auth.uid);

      // Update: Only Admin can reply or change status
      allow update: if isAdmin();
      
      // Delete: Only Admin
      allow delete: if isAdmin();
    }
  }
}
