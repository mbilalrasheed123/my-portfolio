{
  "entities": {
    "Project": {
      "title": "Project",
      "description": "Portfolio project entry",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "category": { "type": "string" },
        "description": { "type": "string" },
        "images": { "type": "array", "items": { "type": "string" } },
        "tags": { "type": "array", "items": { "type": "string" } },
        "github": { "type": "string" },
        "demo": { "type": "string" },
        "order": { "type": "number" },
        "updatedAt": { "type": "string", "format": "date-time" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["title", "category", "description"]
    },
    "Certificate": {
      "title": "Certificate",
      "description": "Professional certificate",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "issuer": { "type": "string" },
        "date": { "type": "string" },
        "image": { "type": "string" },
        "verify": { "type": "string" },
        "link": { "type": "string" },
        "description": { "type": "string" },
        "order": { "type": "number" },
        "updatedAt": { "type": "string", "format": "date-time" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["title", "issuer", "date"]
    },
    "User": {
      "title": "User",
      "description": "Registered user profile",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string" },
        "displayName": { "type": "string" },
        "photoURL": { "type": "string" },
        "lastLogin": { "type": "string", "format": "date-time" },
        "createdAt": { "type": "string", "format": "date-time" },
        "emailVerified": { "type": "boolean" }
      },
      "required": ["uid", "email"]
    },
    "ContactMessage": {
      "title": "Contact Message",
      "description": "User inquiry or question",
      "type": "object",
      "properties": {
        "userName": { "type": "string" },
        "userEmail": { "type": "string" },
        "subject": { "type": "string" },
        "message": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "replied"] },
        "userUid": { "type": "string" },
        "reply": { "type": "string" },
        "repliedAt": { "type": "string", "format": "date-time" },
        "timestamp": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userName", "userEmail", "message", "subject", "status"]
    },
    "Setting": {
      "title": "Site Setting",
      "description": "Global application configuration",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "title": { "type": "string" },
        "subtitle": { "type": "string" },
        "aboutText": { "type": "string" },
        "experienceYears": { "type": "string" },
        "education": { "type": "string" },
        "location": { "type": "string" },
        "email": { "type": "string" },
        "phone": { "type": "string" },
        "updatedAt": { "type": "string", "format": "date-time" }
      }
    }
  },
  "firestore": {
    "/projects/{projectId}": {
      "schema": "Project",
      "description": "Portfolio projects collection"
    },
    "/certificates/{certId}": {
      "schema": "Certificate",
      "description": "Achievements and certifications"
    },
    "/users/{userId}": {
      "schema": "User",
      "description": "Public and private user profiles"
    },
    "/contactMessages/{messageId}": {
      "schema": "ContactMessage",
      "description": "User inquiries"
    },
    "/settings/global": {
      "schema": "Setting",
      "description": "Global configuration document"
    }
  }
}
