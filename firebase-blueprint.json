{
  "entities": {
    "project": {
      "title": "Project",
      "description": "A portfolio project",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "description": { "type": "string" },
        "technologies": { "type": "array", "items": { "type": "string" } },
        "imageUrl": { "type": "string" },
        "projectUrl": { "type": "string" },
        "githubUrl": { "type": "string" },
        "featured": { "type": "boolean" },
        "order": { "type": "number" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["title", "description", "technologies", "order"]
    },
    "skill": {
      "title": "Skill",
      "description": "Technical skill",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "category": { "type": "string" },
        "proficiency": { "type": "number" },
        "icon": { "type": "string" }
      },
      "required": ["name", "category", "proficiency"]
    },
    "experience": {
      "title": "Experience",
      "description": "Work experience",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "company": { "type": "string" },
        "role": { "type": "string" },
        "duration": { "type": "string" },
        "description": { "type": "string" },
        "order": { "type": "number" }
      },
      "required": ["company", "role", "duration", "description", "order"]
    },
    "message": {
      "title": "Contact Message",
      "description": "Contact form submission",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "email": { "type": "string" },
        "message": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" },
        "read": { "type": "boolean" }
      },
      "required": ["name", "email", "message", "timestamp", "read"]
    },
    "about": {
      "title": "About Info",
      "description": "Personal bio and social links",
      "type": "object",
      "properties": {
        "bio": { "type": "string" },
        "resumeUrl": { "type": "string" },
        "socialLinks": {
          "type": "object",
          "properties": {
            "github": { "type": "string" },
            "linkedin": { "type": "string" },
            "twitter": { "type": "string" }
          }
        },
        "profilePic": { "type": "string" }
      }
    },
    "siteConfig": {
      "title": "Site Configuration",
      "description": "General site settings",
      "type": "object",
      "properties": {
        "siteName": { "type": "string" },
        "tagline": { "type": "string" },
        "metadata": { "type": "object" }
      }
    }
  },
  "firestore": {
    "/projects/{projectId}": {
      "schema": "project",
      "description": "Portfolio projects"
    },
    "/skills/{skillId}": {
      "schema": "skill",
      "description": "Technical skills"
    },
    "/experience/{experienceId}": {
      "schema": "experience",
      "description": "Work history"
    },
    "/contactMessages/{messageId}": {
      "schema": "message",
      "description": "Contact form messages"
    },
    "/settings/about": {
      "schema": "about",
      "description": "About section info"
    },
    "/settings/config": {
      "schema": "siteConfig",
      "description": "Site configuration"
    }
  }
}

