{
  "entities": {
    "Project": {
      "title": "Project",
      "description": "Portfolio project entry with iframe support",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "description": { "type": "string" },
        "category": { "type": "string" },
        "technologies": { "type": "array", "items": { "type": "string" } },
        "thumbnailUrl": { "type": "string" },
        "liveUrl": { "type": "string" },
        "githubUrl": { "type": "string" },
        "showInIframe": { "type": "boolean" },
        "showOpenInNewTab": { "type": "boolean" },
        "featured": { "type": "boolean" },
        "order": { "type": "number" },
        "updatedAt": { "type": "string", "format": "date-time" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["title", "description", "category", "liveUrl", "thumbnailUrl"]
    },
    "Certificate": {
      "title": "Certificate",
      "description": "Professional certificate",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "issuer": { "type": "string" },
        "date": { "type": "string" },
        "image": { "type": "string" },
        "verify": { "type": "string" },
        "link": { "type": "string" },
        "description": { "type": "string" },
        "order": { "type": "number" },
        "updatedAt": { "type": "string", "format": "date-time" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["title", "issuer", "date"]
    },
    "User": {
      "title": "User",
      "description": "Registered user profile",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string" },
        "displayName": { "type": "string" },
        "photoURL": { "type": "string" },
        "lastLogin": { "type": "string", "format": "date-time" },
        "createdAt": { "type": "string", "format": "date-time" },
        "emailVerified": { "type": "boolean" }
      },
      "required": ["uid", "email"]
    },
    "ContactMessage": {
      "title": "Contact Message",
      "description": "User inquiry or question",
      "type": "object",
      "properties": {
        "userName": { "type": "string" },
        "userEmail": { "type": "string" },
        "subject": { "type": "string" },
        "message": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "replied"] },
        "userUid": { "type": "string" },
        "reply": { "type": "string" },
        "repliedAt": { "type": "string", "format": "date-time" },
        "timestamp": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userName", "userEmail", "message", "subject", "status"]
    },
    "Setting": {
      "title": "Site Setting",
      "description": "Global application configuration",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "title": { "type": "string" },
        "subtitle": { "type": "string" },
        "aboutText": { "type": "string" },
        "aboutTitle": { "type": "string" },
        "aboutImage": { "type": "string" },
        "experienceYears": { "type": "string" },
        "education": { "type": "string" },
        "location": { "type": "string" },
        "email": { "type": "string" },
        "phone": { "type": "string" },
        "logoType": { "type": "string", "enum": ["text", "image"] },
        "logoText": { "type": "string" },
        "logoUrl": { "type": "string" },
        "logoAlt": { "type": "string" },
        "heroStyle": { "type": "string", "enum": ["default", "particles", "aether", "spline"] },
        "updatedAt": { "type": "string", "format": "date-time" }
      }
    },
    "ChatSession": {
      "title": "Chat Session",
      "description": "History of AI chatbot conversations",
      "type": "object",
      "properties": {
        "userId": { "type": "string", "description": "Auth UID or 'guest'" },
        "userName": { "type": "string" },
        "isGuest": { "type": "boolean" },
        "messages": { 
          "type": "array", 
          "items": {
            "type": "object",
            "properties": {
              "role": { "type": "string", "enum": ["user", "model"] },
              "text": { "type": "string" },
              "timestamp": { "type": "string", "format": "date-time" }
            }
          }
        },
        "lastUpdated": { "type": "string", "format": "date-time" },
        "createdAt": { "type": "string", "format": "date-time" }
      }
    },
    "Lead": {
      "title": "Lead",
      "description": "Potential client interested in services",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "email": { "type": "string" },
        "phone": { "type": "string" },
        "projectDescription": { "type": "string" },
        "source": { "type": "string", "description": "chatbot, contact_form, etc." },
        "status": { "type": "string", "enum": ["new", "contacted", "qualified", "closed"] },
        "userId": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "email"]
    },
    "KnowledgeEntry": {
      "title": "Knowledge Base Entry",
      "description": "Personalized data for AI chatbot context",
      "type": "object",
      "properties": {
        "category": { "type": "string", "enum": ["Basic Info", "Preferences", "Business Info", "Custom Notes", "FAQs"] },
        "title": { "type": "string" },
        "content": { "type": "string" },
        "tags": { "type": "array", "items": { "type": "string" } },
        "isEnabled": { "type": "boolean" },
        "updatedAt": { "type": "string", "format": "date-time" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["category", "title", "content"]
    },
    "AnalyticsEvent": {
      "title": "Analytics Event",
      "description": "Granular user interaction event",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "userEmail": { "type": "string" },
        "sessionId": { "type": "string" },
        "eventType": { "type": "string", "enum": ["page_view", "section_view", "button_click", "scroll_depth", "session_end"] },
        "page": { "type": "string" },
        "section": { "type": "string" },
        "element": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" },
        "duration": { "type": "number" },
        "metadata": {
          "type": "object",
          "properties": {
            "device": { "type": "string", "enum": ["desktop", "mobile", "tablet"] },
            "browser": { "type": "string" },
            "os": { "type": "string" },
            "screenWidth": { "type": "number" },
            "screenHeight": { "type": "number" },
            "referrer": { "type": "string" },
            "userAgent": { "type": "string" }
          }
        },
        "scrollDepth": { "type": "number" },
        "clickPosition": {
          "type": "object",
          "properties": {
            "x": { "type": "number" },
            "y": { "type": "number" }
          }
        }
      },
      "required": ["userId", "sessionId", "eventType", "page", "timestamp"]
    },
    "ApiKey": {
      "title": "API Key",
      "description": "Google AI Studio API Key with rotation tracking",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "key": { "type": "string", "description": "Encrypted AES key" },
        "quota": {
          "type": "object",
          "properties": {
            "rpmUsed": { "type": "integer" },
            "rpdUsed": { "type": "integer" },
            "lastUsed": { "type": "string", "format": "date-time" }
          }
        },
        "status": { "type": "string", "enum": ["active", "exhausted", "disabled"] },
        "priority": { "type": "integer" },
        "updatedAt": { "type": "string", "format": "date-time" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "key", "status", "priority"]
    },
    "Session": {
      "title": "Analytics Session",
      "description": "Aggregated user session data",
      "type": "object",
      "properties": {
        "sessionId": { "type": "string" },
        "userId": { "type": "string" },
        "userEmail": { "type": "string" },
        "startTime": { "type": "string", "format": "date-time" },
        "endTime": { "type": "string", "format": "date-time" },
        "totalDuration": { "type": "number" },
        "pagesVisited": { "type": "array", "items": { "type": "string" } },
        "totalPageViews": { "type": "integer" },
        "totalClicks": { "type": "integer" },
        "totalScrollEvents": { "type": "integer" },
        "entryPage": { "type": "string" },
        "exitPage": { "type": "string" },
        "device": { "type": "string" },
        "browser": { "type": "string" },
        "referrer": { "type": "string" }
      },
      "required": ["sessionId", "userId", "startTime"]
    },
    "DailyStats": {
      "title": "Daily Analytics Aggregate",
      "description": "Pre-aggregated daily statistics",
      "type": "object",
      "properties": {
        "date": { "type": "string" },
        "totalVisitors": { "type": "integer" },
        "authenticatedUsers": { "type": "integer" },
        "anonymousUsers": { "type": "integer" },
        "totalPageViews": { "type": "integer" },
        "topPages": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "page": { "type": "string" },
              "views": { "type": "integer" },
              "avgDuration": { "type": "number" }
            }
          }
        },
        "topSections": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "section": { "type": "string" },
              "views": { "type": "integer" }
            }
          }
        },
        "avgSessionDuration": { "type": "number" },
        "avgPagesPerSession": { "type": "number" },
        "totalClicks": { "type": "integer" },
        "deviceStats": {
          "type": "object",
          "properties": {
            "desktop": { "type": "integer" },
            "mobile": { "type": "integer" },
            "tablet": { "type": "integer" }
          }
        },
        "browserStats": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "browser": { "type": "string" },
              "count": { "type": "integer" }
            }
          }
        },
        "topReferrers": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "source": { "type": "string" },
              "count": { "type": "integer" }
            }
          }
        }
      },
      "required": ["date"]
    }
  },
  "firestore": {
    "/projects/{projectId}": {
      "schema": "Project",
      "description": "Portfolio projects collection"
    },
    "/certificates/{certId}": {
      "schema": "Certificate",
      "description": "Achievements and certifications"
    },
    "/users/{userId}": {
      "schema": "User",
      "description": "Public and private user profiles"
    },
    "/contactMessages/{messageId}": {
      "schema": "ContactMessage",
      "description": "User inquiries"
    },
    "/settings/global": {
      "schema": "Setting",
      "description": "Global configuration document"
    },
    "/chatSessions/{sessionId}": {
      "schema": "ChatSession",
      "description": "Stored chatbot transcripts"
    },
    "/leads/{leadId}": {
      "schema": "Lead",
      "description": "Collected potential client info"
    },
    "/knowledgeBase/{entryId}": {
      "schema": "KnowledgeEntry",
      "description": "Bilal's personalized context for AI"
    },
    "/analytics/{eventId}": {
      "schema": "AnalyticsEvent",
      "description": "Granular engagement tracking"
    },
    "/sessions/{sessionId}": {
      "schema": "Session",
      "description": "User session records"
    },
    "/dailyStats/{date}": {
      "schema": "DailyStats",
      "description": "Daily performance aggregates"
    },
    "/apiKeys/{keyId}": {
      "schema": "ApiKey",
      "description": "API Key rotation management"
    }
  }
}
