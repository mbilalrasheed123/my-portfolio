{
  "entities": {
    "Project": {
      "title": "Project",
      "description": "Portfolio project entry with iframe support",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "description": { "type": "string" },
        "category": { "type": "string" },
        "technologies": { "type": "array", "items": { "type": "string" } },
        "thumbnailUrl": { "type": "string" },
        "liveUrl": { "type": "string" },
        "githubUrl": { "type": "string" },
        "showInIframe": { "type": "boolean" },
        "showOpenInNewTab": { "type": "boolean" },
        "featured": { "type": "boolean" },
        "order": { "type": "number" },
        "updatedAt": { "type": "string", "format": "date-time" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["title", "description", "category", "liveUrl", "thumbnailUrl"]
    },
    "Certificate": {
      "title": "Certificate",
      "description": "Professional certificate",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "issuer": { "type": "string" },
        "date": { "type": "string" },
        "image": { "type": "string" },
        "verify": { "type": "string" },
        "link": { "type": "string" },
        "description": { "type": "string" },
        "order": { "type": "number" },
        "updatedAt": { "type": "string", "format": "date-time" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["title", "issuer", "date"]
    },
    "User": {
      "title": "User",
      "description": "Registered user profile",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string" },
        "displayName": { "type": "string" },
        "photoURL": { "type": "string" },
        "lastLogin": { "type": "string", "format": "date-time" },
        "createdAt": { "type": "string", "format": "date-time" },
        "emailVerified": { "type": "boolean" }
      },
      "required": ["uid", "email"]
    },
    "ContactMessage": {
      "title": "Contact Message",
      "description": "User inquiry or question",
      "type": "object",
      "properties": {
        "userName": { "type": "string" },
        "userEmail": { "type": "string" },
        "subject": { "type": "string" },
        "message": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "replied"] },
        "userUid": { "type": "string" },
        "reply": { "type": "string" },
        "repliedAt": { "type": "string", "format": "date-time" },
        "timestamp": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userName", "userEmail", "message", "subject", "status"]
    },
    "Setting": {
      "title": "Site Setting",
      "description": "Global application configuration",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "title": { "type": "string" },
        "subtitle": { "type": "string" },
        "aboutText": { "type": "string" },
        "aboutTitle": { "type": "string" },
        "aboutImage": { "type": "string" },
        "experienceYears": { "type": "string" },
        "education": { "type": "string" },
        "location": { "type": "string" },
        "email": { "type": "string" },
        "phone": { "type": "string" },
        "logoType": { "type": "string", "enum": ["text", "image"] },
        "logoText": { "type": "string" },
        "logoUrl": { "type": "string" },
        "logoAlt": { "type": "string" },
        "heroStyle": { "type": "string", "enum": ["default", "particles", "aether", "spline"] },
        "heroDesignLoop": { "type": "boolean" },
        "heroLoopOrder": { 
          "type": "array", 
          "items": { "type": "string", "enum": ["default", "particles", "aether", "spline"] },
          "description": "The sequence of hero designs to cycle through on refresh"
        },
        "mobileHeroStyle": { "type": "string", "enum": ["sameAsDesktop", "default", "particles", "aether", "spline"] },
        "updatedAt": { "type": "string", "format": "date-time" }
      }
    },
    "ChatSession": {
      "title": "Chat Session",
      "description": "History of AI chatbot conversations",
      "type": "object",
      "properties": {
        "userId": { "type": "string", "description": "Auth UID or 'guest'" },
        "userName": { "type": "string" },
        "isGuest": { "type": "boolean" },
        "messages": { 
          "type": "array", 
          "items": {
            "type": "object",
            "properties": {
              "role": { "type": "string", "enum": ["user", "model"] },
              "text": { "type": "string" },
              "timestamp": { "type": "string", "format": "date-time" }
            }
          }
        },
        "lastUpdated": { "type": "string", "format": "date-time" },
        "createdAt": { "type": "string", "format": "date-time" }
      }
    },
    "Lead": {
      "title": "Lead",
      "description": "Potential client interested in services",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "email": { "type": "string" },
        "phone": { "type": "string" },
        "projectDescription": { "type": "string" },
        "source": { "type": "string", "description": "chatbot, contact_form, etc." },
        "status": { "type": "string", "enum": ["new", "contacted", "qualified", "closed"] },
        "userId": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "email"]
    },
    "KnowledgeEntry": {
      "title": "Knowledge Base Entry",
      "description": "Personalized data for AI chatbot context",
      "type": "object",
      "properties": {
        "category": { "type": "string", "enum": ["Basic Info", "Preferences", "Business Info", "Custom Notes", "FAQs"] },
        "title": { "type": "string" },
        "content": { "type": "string" },
        "tags": { "type": "array", "items": { "type": "string" } },
        "isEnabled": { "type": "boolean" },
        "updatedAt": { "type": "string", "format": "date-time" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["category", "title", "content"]
    },
    "AnalyticsEvent": {
      "title": "Analytics Event",
      "description": "Granular user interaction event",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "userEmail": { "type": "string" },
        "sessionId": { "type": "string" },
        "eventType": { "type": "string", "enum": ["page_view", "section_view", "button_click", "scroll_depth", "session_end"] },
        "page": { "type": "string" },
        "section": { "type": "string" },
        "element": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" },
        "duration": { "type": "number" },
        "metadata": {
          "type": "object",
          "properties": {
            "device": { "type": "string", "enum": ["desktop", "mobile", "tablet"] },
            "browser": { "type": "string" },
            "os": { "type": "string" },
            "screenWidth": { "type": "number" },
            "screenHeight": { "type": "number" },
            "referrer": { "type": "string" },
            "userAgent": { "type": "string" }
          }
        },
        "scrollDepth": { "type": "number" },
        "clickPosition": {
          "type": "object",
          "properties": {
            "x": { "type": "number" },
            "y": { "type": "number" }
          }
        }
      },
      "required": ["userId", "sessionId", "eventType", "page", "timestamp"]
    },
    "ApiKey": {
      "title": "API Key",
      "description": "Google AI Studio API Key with rotation tracking",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "key": { "type": "string", "description": "Encrypted AES key" },
        "quota": {
          "type": "object",
          "properties": {
            "rpmUsed": { "type": "integer" },
            "rpdUsed": { "type": "integer" },
            "lastUsed": { "type": "string", "format": "date-time" }
          }
        },
        "status": { "type": "string", "enum": ["active", "exhausted", "disabled"] },
        "priority": { "type": "integer" },
        "updatedAt": { "type": "string", "format": "date-time" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "key", "status", "priority"]
    },
    "ChatMessage": {
      "title": "Chat Message Log",
      "description": "Log of a single chat message exchanged with the AI chatbot, used for rotating key stats",
      "type": "object",
      "properties": {
        "sessionId": { "type": "string" },
        "userMessage": { "type": "string" },
        "botResponse": { "type": "string" },
        "apiKeyUsed": { "type": "string" },
        "apiKeyName": { "type": "string" },
        "messageNumberOverall": { "type": "integer" },
        "messageNumberForKey": { "type": "integer" },
        "responseTime": { "type": "number" },
        "status": { "type": "string" },
        "errorMessage": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" }
      }
    },
    "Session": {
      "title": "Analytics Session",
      "description": "Aggregated user session data",
      "type": "object",
      "properties": {
        "sessionId": { "type": "string" },
        "userId": { "type": "string" },
        "userEmail": { "type": "string" },
        "startTime": { "type": "string", "format": "date-time" },
        "endTime": { "type": "string", "format": "date-time" },
        "totalDuration": { "type": "number" },
        "pagesVisited": { "type": "array", "items": { "type": "string" } },
        "totalPageViews": { "type": "integer" },
        "totalClicks": { "type": "integer" },
        "totalScrollEvents": { "type": "integer" },
        "entryPage": { "type": "string" },
        "exitPage": { "type": "string" },
        "device": { "type": "string" },
        "browser": { "type": "string" },
        "referrer": { "type": "string" }
      },
      "required": ["sessionId", "userId", "startTime"]
    },
    "DailyStats": {
      "title": "Daily Analytics Aggregate",
      "description": "Pre-aggregated daily statistics",
      "type": "object",
      "properties": {
        "date": { "type": "string" },
        "totalVisitors": { "type": "integer" },
        "authenticatedUsers": { "type": "integer" },
        "anonymousUsers": { "type": "integer" },
        "totalPageViews": { "type": "integer" },
        "topPages": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "page": { "type": "string" },
              "views": { "type": "integer" },
              "avgDuration": { "type": "number" }
            }
          }
        },
        "topSections": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "section": { "type": "string" },
              "views": { "type": "integer" }
            }
          }
        },
        "avgSessionDuration": { "type": "number" },
        "avgPagesPerSession": { "type": "number" },
        "totalClicks": { "type": "integer" },
        "deviceStats": {
          "type": "object",
          "properties": {
            "desktop": { "type": "integer" },
            "mobile": { "type": "integer" },
            "tablet": { "type": "integer" }
          }
        },
        "browserStats": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "browser": { "type": "string" },
              "count": { "type": "integer" }
            }
          }
        },
        "topReferrers": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "source": { "type": "string" },
              "count": { "type": "integer" }
            }
          }
        }
      },
      "required": ["date"]
    },
    "Testimonial": {
      "title": "Testimonial",
      "description": "Client endorsement and review",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "role": { "type": "string" },
        "company": { "type": "string" },
        "text": { "type": "string" },
        "message": { "type": "string" },
        "avatar": { "type": "string" },
        "rating": { "type": "number" },
        "order": { "type": "number" },
        "approved": { "type": "boolean" },
        "status": { "type": "string" },
        "isApproved": { "type": "boolean" },
        "visible": { "type": "boolean" },
        "userId": { "type": "string" },
        "updatedAt": { "type": "string", "format": "date-time" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "role", "text"]
    },
    "Campaign": {
      "title": "Campaign",
      "description": "Email marketing campaign details",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "subject": { "type": "string" },
        "content": { "type": "string" },
        "templateId": { "type": "string" },
        "status": { "type": "string", "enum": ["active", "draft", "completed", "paused", "failed"] },
        "sentCount": { "type": "number" },
        "totalRecipients": { "type": "number" },
        "scheduledAt": { "type": "string", "format": "date-time" },
        "createdBy": { "type": "string" },
        "errorMessage": { "type": "string" },
        "updatedAt": { "type": "string", "format": "date-time" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["title", "subject", "content", "status"]
    },
    "EmailTemplate": {
      "title": "EmailTemplate",
      "description": "Reusable email template design",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "subject": { "type": "string" },
        "bodyHtml": { "type": "string" },
        "bodyText": { "type": "string" },
        "status": { "type": "string", "enum": ["active", "draft"] },
        "createdBy": { "type": "string" },
        "updatedAt": { "type": "string", "format": "date-time" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "subject", "bodyHtml"]
    },
    "EmailLog": {
      "title": "EmailLog",
      "description": "Log entry tracking email transmission success or failure",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "campaignId": { "type": "string" },
        "recipientEmail": { "type": "string" },
        "status": { "type": "string", "enum": ["sent", "failed", "pending"] },
        "errorMessage": { "type": "string" },
        "smtpUsed": { "type": "string" },
        "sentAt": { "type": "string", "format": "date-time" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["campaignId", "recipientEmail", "status"]
    },
    "EmailSetting": {
      "title": "EmailSetting",
      "description": "Email marketing system configuration and rate limiting",
      "type": "object",
      "properties": {
        "dailyLimit": { "type": "number" },
        "emailsSentToday": { "type": "number" },
        "lastSentDate": { "type": "string" },
        "batchSize": { "type": "number" },
        "autoPause": { "type": "boolean" },
        "updatedAt": { "type": "string", "format": "date-time" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["dailyLimit", "emailsSentToday"]
    },
    "CampaignRecipient": {
      "title": "CampaignRecipient",
      "description": "Recipient address queue mapped to a specific campaign",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "campaignId": { "type": "string" },
        "email": { "type": "string" },
        "name": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "sent", "failed"] },
        "sentAt": { "type": "string", "format": "date-time" },
        "errorMessage": { "type": "string" },
        "updatedAt": { "type": "string", "format": "date-time" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["campaignId", "email", "status"]
    },
    "AICampaign": {
      "title": "AICampaign",
      "description": "AI-powered personalized email campaign details",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "description": { "type": "string" },
        "status": { "type": "string", "enum": ["draft", "active", "paused", "completed"] },
        "totalLeads": { "type": "number" },
        "sentCount": { "type": "number" },
        "failedCount": { "type": "number" },
        "remainingCount": { "type": "number" },
        "lastProcessedLeadId": { "type": "string" },
        "geminiModel": { "type": "string", "enum": ["flash", "flash-lite", "2.5-flash", "2.5-pro"] },
        "imageStrategy": { "type": "string", "enum": ["option1-keyword", "option2-unsplash-dynamic"] },
        "imageKeywordTemplate": { "type": "string" },
        "instructions": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" },
        "startedAt": { "type": "string", "format": "date-time" },
        "completedAt": { "type": "string", "format": "date-time" },
        "summary": {
          "type": "object",
          "properties": {
            "totalBatches": { "type": "number" },
            "batchesProcessed": { "type": "number" },
            "estimatedTimeRemaining": { "type": "string" }
          }
        }
      },
      "required": ["title", "status", "geminiModel", "imageStrategy", "instructions"]
    },
    "AICampaignLead": {
      "title": "AICampaignLead",
      "description": "Lead for an AI personalized campaign",
      "type": "object",
      "properties": {
        "email": { "type": "string" },
        "name": { "type": "string" },
        "businessType": { "type": "string" },
        "businessName": { "type": "string" },
        "city": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "generated", "sent", "failed"] },
        "generatedEmail": {
          "type": "object",
          "properties": {
            "subject": { "type": "string" },
            "htmlBody": { "type": "string" },
            "selectedImageUrl": { "type": "string" }
          }
        },
        "sentAt": { "type": "string", "format": "date-time" },
        "errorMessage": { "type": "string" },
        "retryCount": { "type": "number" },
        "batchNumber": { "type": "number" }
      },
      "required": ["email", "name", "status"]
    },
    "AICampaignLog": {
      "title": "AICampaignLog",
      "description": "Granular execution trace for AI campaign dispatches",
      "type": "object",
      "properties": {
        "leadId": { "type": "string" },
        "email": { "type": "string" },
        "name": { "type": "string" },
        "batchNumber": { "type": "number" },
        "status": { "type": "string", "enum": ["sent", "failed"] },
        "sentAt": { "type": "string", "format": "date-time" },
        "errorMessage": { "type": "string" },
        "emailContent": {
          "type": "object",
          "properties": {
            "subject": { "type": "string" },
            "body": { "type": "string" },
            "imageUrl": { "type": "string" }
          }
        },
        "geminiRequestId": { "type": "string" }
      },
      "required": ["leadId", "email", "status"]
    },
    "AICampaignSettings": {
      "title": "AICampaignSettings",
      "description": "Singleton configuration for AI campaigns and RPM limiting",
      "type": "object",
      "properties": {
        "modelConfigs": {
          "type": "object",
          "properties": {
            "flash": { "type": "object", "properties": { "rpm": { "type": "number" }, "rpd": { "type": "number" } } },
            "flash-lite": { "type": "object", "properties": { "rpm": { "type": "number" }, "rpd": { "type": "number" } } },
            "2.5-flash": { "type": "object", "properties": { "rpm": { "type": "number" }, "rpd": { "type": "number" } } },
            "2.5-pro": { "type": "object", "properties": { "rpm": { "type": "number" }, "rpd": { "type": "number" } } }
          }
        },
        "lastGeminiRequestTime": { "type": "string", "format": "date-time" },
        "requestCountThisMinute": { "type": "number" },
        "imageStrategy": { "type": "string" }
      }
    }
  },
  "firestore": {
    "/projects/{projectId}": {
      "schema": "Project",
      "description": "Portfolio projects collection"
    },
    "/certificates/{certId}": {
      "schema": "Certificate",
      "description": "Achievements and certifications"
    },
    "/users/{userId}": {
      "schema": "User",
      "description": "Public and private user profiles"
    },
    "/contactMessages/{messageId}": {
      "schema": "ContactMessage",
      "description": "User inquiries"
    },
    "/settings/global": {
      "schema": "Setting",
      "description": "Global configuration document"
    },
    "/chatSessions/{sessionId}": {
      "schema": "ChatSession",
      "description": "Stored chatbot transcripts"
    },
    "/leads/{leadId}": {
      "schema": "Lead",
      "description": "Collected potential client info"
    },
    "/knowledgeBase/{entryId}": {
      "schema": "KnowledgeEntry",
      "description": "Bilal's personalized context for AI"
    },
    "/analytics/{eventId}": {
      "schema": "AnalyticsEvent",
      "description": "Granular engagement tracking"
    },
    "/chatMessages/{messageId}": {
      "schema": "ChatMessage",
      "description": "Granular logging of chat transactions for key API service level indicator monitoring"
    },
    "/sessions/{sessionId}": {
      "schema": "Session",
      "description": "User session records"
    },
    "/dailyStats/{date}": {
      "schema": "DailyStats",
      "description": "Daily performance aggregates"
    },
    "/apiKeys/{keyId}": {
      "schema": "ApiKey",
      "description": "API Key rotation management"
    },
    "/testimonials/{testId}": {
      "schema": "Testimonial",
      "description": "Client endorsements listed on portfolio landing page"
    },
    "/campaigns/{campaignId}": {
      "schema": "Campaign",
      "description": "Email marketing campaigns list"
    },
    "/emailTemplates/{templateId}": {
      "schema": "EmailTemplate",
      "description": "Reusable template layouts for email campaigns"
    },
    "/emailLogs/{logId}": {
      "schema": "EmailLog",
      "description": "Trace log logs for send history & failure status"
    },
    "/emailSettings/{settingId}": {
      "schema": "EmailSetting",
      "description": "System throttling, bounds, limits, counters"
    },
    "/campaignRecipients/{recipientId}": {
      "schema": "CampaignRecipient",
      "description": "Recipients to process per campaign"
    },
    "/aiCampaigns/{campaignId}": {
      "schema": "AICampaign",
      "description": "AI personalization campaign details"
    },
    "/aiCampaigns/{campaignId}/leads/{leadId}": {
      "schema": "AICampaignLead",
      "description": "Target lead list and generation state for an AI campaign"
    },
    "/aiCampaigns/{campaignId}/logs/{logId}": {
      "schema": "AICampaignLog",
      "description": "Execution and dispatch log traces for AI campaign leads"
    },
    "/aiCampaignSettings/{settingId}": {
      "schema": "AICampaignSettings",
      "description": "Singleton or model configurations for AI campaign rate limits"
    }
  }
}
