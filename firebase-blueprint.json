{
  "entities": {
    "project": {
      "title": "Project",
      "description": "A portfolio project",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "category": { "type": "string" },
        "description": { "type": "string" },
        "images": { "type": "array", "items": { "type": "string" } },
        "tags": { "type": "array", "items": { "type": "string" } },
        "github": { "type": "string" },
        "demo": { "type": "string" },
        "order": { "type": "number" }
      },
      "required": ["title", "category", "description", "images", "tags"]
    },
    "siteSettings": {
      "title": "Site Settings",
      "description": "Global site information",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "title": { "type": "string" },
        "subtitle": { "type": "string" },
        "aboutText": { "type": "string" },
        "email": { "type": "string" },
        "phone": { "type": "string" },
        "location": { "type": "string" },
        "githubUrl": { "type": "string" },
        "linkedinUrl": { "type": "string" },
        "twitterUrl": { "type": "string" }
      }
    },
    "query": {
      "title": "Query",
      "description": "A user query or message",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "userName": { "type": "string" },
        "userEmail": { "type": "string" },
        "subject": { "type": "string" },
        "message": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "replied"] },
        "reply": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "repliedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "userName", "userEmail", "subject", "message", "status", "createdAt"]
    },
    "user": {
      "title": "User",
      "description": "Registered user profile information.",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string" },
        "displayName": { "type": "string" },
        "photoURL": { "type": "string" },
        "lastLogin": { "type": "string", "format": "date-time" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email", "createdAt"]
    },
    "certificate": {
      "title": "Certificate",
      "description": "A professional certificate",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "issuer": { "type": "string" },
        "date": { "type": "string" },
        "image": { "type": "string" },
        "link": { "type": "string" },
        "verify": { "type": "string" },
        "order": { "type": "number" }
      },
      "required": ["title", "issuer", "date", "image"]
    }
  },
  "firestore": {
    "/projects/{projectId}": {
      "schema": "project",
      "description": "Collection of portfolio projects"
    },
    "/settings/global": {
      "schema": "siteSettings",
      "description": "Global site settings"
    },
    "/queries/{queryId}": {
      "schema": "query",
      "description": "User queries and messages"
    },
    "/users/{userId}": {
      "schema": "user",
      "description": "User profiles."
    },
    "/certificates/{certificateId}": {
      "schema": "certificate",
      "description": "Collection of professional certificates"
    }
  }
}
