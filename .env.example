# Firebase Config
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
VITE_FIREBASE_FIRESTORE_DATABASE_ID=

# Firebase Admin SDK (For server-side operations)
FIREBASE_PROJECT_ID=
FIREBASE_ADMIN_CLIENT_EMAIL=
FIREBASE_ADMIN_PRIVATE_KEY=

# Email Notification (SMTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
CRON_SECRET=

# Cloudinary Storage
# To use Cloudinary: 
# 1. Create a Cloudinary account.
# 2. Find your 'Cloud Name' in the Dashboard.
# 3. Go to Settings -> Upload -> Upload presets -> Add upload preset.
# 4. Set 'Signing Mode' to 'Unsigned' and note the 'Upload preset name'.
VITE_CLOUDINARY_CLOUD_NAME=
VITE_CLOUDINARY_UPLOAD_PRESET=
VITE_CLOUDINARY_API_KEY=
# Note: Signed uploads (using API Secret) are not implemented for security in frontend. 
# Please use an UNSIGNED upload preset.

# API Key Rotation Security
API_KEY_ENCRYPTION_SECRET=
