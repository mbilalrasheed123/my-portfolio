rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ---------------------------------------------------------
    // 1. GLOBAL HELPERS & AUTHENTICATION
    // ---------------------------------------------------------
    function isSignedIn() { return request.auth != null; }
    function isAdmin() { 
      return isSignedIn() && (
        (request.auth.token.email == "muhammadbilalrasheed78@gmail.com" && request.auth.token.email_verified == true) ||
        exists(/databases/$(database)/documents/admins/$(request.auth.uid))
      );
    }
    function isOwner(userId) { return isSignedIn() && request.auth.uid == userId; }
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }

    // ---------------------------------------------------------
    // 2. DEFAULT SAFETY NET
    // ---------------------------------------------------------
    match /{document=**} {
      allow read, write: if false;
    }

    // ---------------------------------------------------------
    // 3. ADMIN-ONLY RESOURCE ACCESS
    // ---------------------------------------------------------
    match /admins/{adminId} {
      allow read, write: if isAdmin();
    }

    match /apiKeys/{keyId} {
      allow read, write: if isAdmin();
    }

    // ---------------------------------------------------------
    // 4. PORTFOLIO DATA COLLECTIONS (Public Read, Admin Write)
    // ---------------------------------------------------------
    match /projects/{projectId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }
    
    match /certificates/{certId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }

    match /skills/{skillId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }

    match /experience/{expId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }

    match /testimonials/{testId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }

    match /settings/{settingId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }

    match /knowledgeBase/{entryId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }

    // ---------------------------------------------------------
    // 5. USER PROFILES & CHAT INFRASTRUCTURE
    // ---------------------------------------------------------
    match /users/{userId} {
      allow read, write: if isOwner(userId) || isAdmin();
    }

    match /chatSessions/{sessionId} {
      allow create: if true;
      allow read, update: if isAdmin() || (isSignedIn() && resource.data.userId == request.auth.uid);
      allow delete: if isAdmin();
    }

    match /chatMessages/{messageId} {
      allow create: if true;
      allow read, update: if isAdmin() || (isSignedIn() && resource.data.userId == request.auth.uid);
      allow delete: if isAdmin();
    }

    match /leads/{leadId} {
      allow create: if true;
      allow read, update: if isAdmin() || (isSignedIn() && resource.data.userId == request.auth.uid);
      allow delete: if isAdmin();
    }

    // ---------------------------------------------------------
    // 6. CONTACT MESSAGES (Queries)
    // ---------------------------------------------------------
    match /contactMessages/{messageId} {
      allow create: if true;
      allow list, get: if isAdmin() || (isSignedIn() && resource.data.userUid == request.auth.uid);
      allow update, delete: if isAdmin();
    }

    // ---------------------------------------------------------
    // 7. COUNTER & STATS PROTECTION
    // ---------------------------------------------------------
    match /portfolioStats/{statId} {
      allow read, write: if true;
    }

    match /dailyStats/{date} {
      allow read, write: if isAdmin();
    }

    match /analytics/{eventId} {
      allow write: if true;
      allow read: if isAdmin();
    }

    match /sessions/{sessionId} {
      allow write: if true;
      allow read: if isAdmin();
    }
  }
}
