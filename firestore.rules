rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ---------------------------------------------------------
    // 1. GLOBAL HELPERS
    // ---------------------------------------------------------
    function isSignedIn() { return request.auth != null; }
    function isAdmin() { 
      return isSignedIn() && (
        (request.auth.token.email == "muhammadbilalrasheed78@gmail.com" && request.auth.token.email_verified == true) ||
        exists(/databases/$(database)/documents/admins/$(request.auth.uid))
      );
    }
    function isOwner(userId) { return isSignedIn() && request.auth.uid == userId; }
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }

    // ---------------------------------------------------------
    // 2. SAFETY NET
    // ---------------------------------------------------------
    match /{document=**} {
      allow read, write: if false;
    }

    // ---------------------------------------------------------
    // 3. COLLECTIONS
    // ---------------------------------------------------------

    // Public Collections (Read-Only for public, Write for Owner/Admin)
    match /projects/{projectId} {
      allow read: if true;
      allow write: if isAdmin() || (isSignedIn() && (
        (request.method == 'create' && incoming().userId == request.auth.uid) ||
        (request.method != 'create' && existing().userId == request.auth.uid)
      ));
    }
    
    match /certificates/{certId} {
      allow read: if true;
      allow write: if isAdmin() || (isSignedIn() && (
        (request.method == 'create' && incoming().userId == request.auth.uid) ||
        (request.method != 'create' && existing().userId == request.auth.uid)
      ));
    }

    function isValidSetting(data) {
      return data.keys().hasAll(['updatedAt']) &&
             (!data.keys().hasAny(['name']) || data.name is string) &&
             (!data.keys().hasAny(['title']) || data.title is string) &&
             (!data.keys().hasAny(['aboutText']) || data.aboutText is string) &&
             (!data.keys().hasAny(['aboutImage']) || data.aboutImage is string);
    }

    match /settings/{settingId} {
      allow read: if true;
      allow write: if isAdmin() || (isSignedIn() && settingId == request.auth.uid && isValidSetting(incoming()));
    }

    // User Profiles
    match /users/{userId} {
      allow read: if isSignedIn() && (isOwner(userId) || isAdmin());
      allow create: if isSignedIn() && isOwner(userId) &&
        incoming().keys().hasAll(['uid', 'email']) &&
        incoming().uid == request.auth.uid;
      allow update: if isSignedIn() && (isOwner(userId) || isAdmin()) &&
        incoming().uid == existing().uid; // UID is immutable
      // List users: Only Admin
      allow list: if isAdmin();
    }

    // Chat Sessions
    match /chatSessions/{sessionId} {
      allow read: if isAdmin() || (isSignedIn() && resource.data.userId == request.auth.uid);
      allow create: if true;
      allow update: if isAdmin() || (isSignedIn() && resource.data.userId == request.auth.uid);
      allow list: if isAdmin() || (isSignedIn() && resource.data.userId == request.auth.uid);
    }

    // Leads
    match /leads/{leadId} {
      allow read: if isAdmin() || (isSignedIn() && resource.data.userId == request.auth.uid);
      allow create: if true;
      allow update: if isAdmin() || (isSignedIn() && resource.data.userId == request.auth.uid);
      allow delete: if isAdmin();
      allow list: if isAdmin() || (isSignedIn() && resource.data.userId == request.auth.uid);
    }

    // Knowledge Base
    match /knowledgeBase/{entryId} {
      allow read: if true; 
      allow write: if isAdmin() || (isSignedIn() && (
        (request.method == 'create' && incoming().userId == request.auth.uid) ||
        (request.method != 'create' && (existing().userId == request.auth.uid || !existing().keys().hasAny(['userId'])))
      ));
    }

    // Contact Messages (Queries)
    match /contactMessages/{messageId} {
      allow create: if 
        incoming().keys().hasAll(['userName', 'userEmail', 'message', 'subject', 'status']) &&
        (incoming().userUid == null || incoming().userUid == request.auth.uid);

      allow list: if isAdmin() || (isSignedIn() && resource.data.userUid == request.auth.uid);
      allow get: if isAdmin() || (isSignedIn() && resource.data.userUid == request.auth.uid);
      allow update: if isAdmin() || (isSignedIn() && resource.data.userUid == request.auth.uid); // Sender/Recipient can update (e.g. status or reply)
      allow delete: if isAdmin();
    }
  }
}
