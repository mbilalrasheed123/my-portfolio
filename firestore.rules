rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper to identify the admin
    function isAdmin() {
      return request.auth != null && 
        request.auth.token.email == "muhammadbilalrasheed78@gmail.com" &&
        request.auth.token.email_verified == true;
    }

    // Publicly readable content
    match /projects/{id} { allow read: if true; allow write: if isAdmin(); }
    match /skills/{id} { allow read: if true; allow write: if isAdmin(); }
    match /experience/{id} { allow read: if true; allow write: if isAdmin(); }
    match /certificates/{id} { allow read: if true; allow write: if isAdmin(); }
    match /settings/{id} { allow read: if true; allow write: if isAdmin(); }

    // Contact Messages: Public can create, only admin can manage
    match /contactMessages/{messageId} {
      allow create: if true;
      allow read, update, delete: if isAdmin();
    }

    // Default deny for everything else
    match /{document=**} {
      allow read, write: if false;
    }
  }
}



