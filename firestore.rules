rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper to identify the admin
    function isAdmin() {
      return request.auth != null && 
        request.auth.token.email == "muhammadbilalrasheed78@gmail.com" &&
        request.auth.token.email_verified == true;
    }

    // Publicly readable content
    match /projects/{id} { allow read: if true; allow write: if isAdmin(); }
    match /skills/{id} { allow read: if true; allow write: if isAdmin(); }
    match /experience/{id} { allow read: if true; allow write: if isAdmin(); }
    match /certificates/{id} { allow read: if true; allow write: if isAdmin(); }
    match /settings/{id} { allow read: if true; allow write: if isAdmin(); }

    // Users collection: users can read/write their own data
    match /users/{userId} {
      allow read: if request.auth != null && (request.auth.uid == userId || request.auth.token.email == resource.data.email || isAdmin());
      allow create: if request.auth != null;
      allow update, delete: if request.auth != null && (request.auth.uid == userId || isAdmin());
    }

    // Contact Messages: Public/Users can create, admin can manage, users can read their own
    match /contactMessages/{messageId} {
      allow create: if true;
      allow read: if isAdmin() || (request.auth != null && request.auth.token.email == resource.data.userEmail);
      allow update, delete: if isAdmin();
    }

    // Default deny for everything else
    match /{document=**} {
      allow read, write: if false;
    }
  }
}



