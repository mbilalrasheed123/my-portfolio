{
  "version": 2,
  "builds": [
    {
      "src": "package.json",
      "use": "@vercel/static-build",
      "config": { "distDir": "dist" }
    },
    {
      "src": "server.ts",
      "use": "@vercel/node"
    },
    {
      "src": "api/**/*.mjs",
      "use": "@vercel/node"
    }
  ],
  "rewrites": [
    {
      "source": "/api/cron/(.*)",
      "destination": "/api/cron/$1.mjs"
    },
    {
      "source": "/api/keys/(.*)",
      "destination": "/api/keys/$1.mjs"
    },
    {
      "source": "/api/(.*)",
      "destination": "/server.ts"
    },
    {
      "source": "/((?!api/|.*\\.).*)",
      "destination": "/index.html"
    }
  ],
  "crons": [
    {
      "path": "/api/cron/aggregate-analytics",
      "schedule": "0 1 * * *"
    },
    {
      "path": "/api/cron/cleanup-analytics",
      "schedule": "0 2 1 * *"
    }
  ]
}
